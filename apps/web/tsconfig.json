{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@qixu/ui/*": ["../../packages/ui/src/*"],
      "@qixu/config/*": ["../../packages/config/src/*"],
      "@qixu/types/*": ["../../packages/types/src/*"],
      "@qixu/utils/*": ["../../packages/utils/src/*"],
      "@qixu/domain/*": ["../../packages/domain/src/*"],
      "@qixu/domain": ["../../packages/domain/src/index.ts"],
      "@qixu/contracts/*": ["../../packages/contracts/src/*"],
      "@qixu/mock/*": ["../../packages/mock/src/*"],
      "@qixu/schemas/*": ["../../packages/schemas/src/*"],
      "@qixu/domain-runtime/*": ["../../packages/domain-runtime/src/*"],
      "@qixu/data-quality/*": ["../../packages/data-quality/src/*"],
      "@qixu/data-quality": ["../../packages/data-quality/src/index.ts"],
      "@qixu/data-pipeline/*": ["../../packages/data-pipeline/src/*"],
      "@qixu/data-pipeline": ["../../packages/data-pipeline/src/index.ts"],
      "@qixu/seo/*": ["../../packages/seo/src/*"],
      "@qixu/seo": ["../../packages/seo/src/index.ts"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
